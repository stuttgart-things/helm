---
kubeProxyReplacement: true
routingMode: "native"
ipv4NativeRoutingCIDR: "10.244.0.0/16"
k8sServiceHost: "{{ .Values.clusterName }}"
k8sServicePort: 6443

l2announcements:
  enabled: true
  leaseDuration: "3s"
  leaseRenewDeadline: "1s"
  leaseRetryPeriod: "500ms"

devices: ["{{ .Values.networkDevice }}"]

externalIPs:
  enabled: true

autoDirectNodeRoutes: true

operator:
  replicas: 1
