---
customresources:
  harbor-httproute:
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      name: harbor
      namespace: {{ .Values.namespace }}
    spec:
      parentRefs:
        - name: {{ .Values.gatewayName }}
          namespace: {{ .Values.gatewayNamespace }}
      hostnames:
        - "{{ .Values.hostname }}.{{ .Values.domain }}"
      rules:
        - backendRefs:
            - name: harbor
              port: 443
